 *
 * SPDX-License-Identifier: MIT
 *
 * DM45 — 46-key split dactyl-manuform-style keyboard
 * Matrix: 5 rows x 5 cols per side, COL2ROW
 *
 * Left  peripheral: local rows 0-4  cols 0-4  → keymap cols 0-4
 * Right peripheral: local rows 0-4  cols 0-4  → keymap cols 5-9 (col-offset = 5)
 *
 * NOTE: kscan0 has NO `compatible` here — the peripheral overlays add it.
 *       This allows the dongle overlay to include this file, inherit the
 *       transform, and override only zmk,kscan (Solfe pattern).
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    /* ------------------------------------------------------------------ *
     *  Default transform — full-keyboard view (10 logical columns).       *
     *  The right overlay sets col-offset = <5> so its local cols 0-4      *
     *  map to logical cols 5-9.                                           *
     *                                                                    *
     *  Logical key positions:                                             *
     *                                                                     *
     *  RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)     top alpha (left)     *
     *  RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)     top alpha (right)    *
     *  RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)     home row  (left)     *
     *  RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)     home row  (right)    *
     *  RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)     bottom row (left)   *
     *  RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)     bottom row (right)  *
     *          RC(3,1) RC(3,2)                       inner col  (left)   *
     *                                  RC(3,7) RC(3,8) inner col  (right) *
     *                  RC(3,3) RC(3,4)               thumb top  (left)   *
     *                  RC(3,5) RC(3,6)               thumb top  (right)  *
     *                          RC(4,3) RC(4,4)       thumb bot  (left)   *
     *                          RC(4,7) RC(4,8)       thumb bot  (right)  *
     *                  RC(4,1) RC(4,2)               inner low  (left)   *
     *                  RC(4,5) RC(4,6)               inner low  (right)  *
     * ------------------------------------------------------------------ */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <5>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)     RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)     RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)     RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
                    RC(3,1) RC(3,2)                                         RC(3,7) RC(3,8)
                                    RC(3,3) RC(3,4)     RC(3,5) RC(3,6)
                                            RC(4,3) RC(4,4)     RC(4,7) RC(4,8)
                            RC(4,1) RC(4,2)                     RC(4,5) RC(4,6)
        >;
    };

    /* ------------------------------------------------------------------ *
     *  kscan0 skeleton — NO compatible here (Solfe pattern).              *
     *  Peripheral overlays add compatible + row-gpios + col-gpios.        *
     *  The dongle overlay overrides zmk,kscan with a mock kscan.          *
     * ------------------------------------------------------------------ */
    kscan0: kscan {
        diode-direction = "col2row";
        wakeup-source;
    };
};
