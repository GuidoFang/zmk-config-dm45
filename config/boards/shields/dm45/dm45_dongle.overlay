 *
 * DM45 BLE central dongle — nice!nano v2 (Pro Micro footprint).
 *
 * Includes dm45.dtsi to inherit the default_transform, then overrides
 * only zmk,kscan with a mock kscan (no physical matrix on the dongle).
 * This is the exact same pattern used by zmk-solfe-dongle.
 */

#include "dm45.dtsi"

/ {
    chosen {
        zmk,kscan = &mock_kscan;
    };

    mock_kscan: mock_kscan {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };
};
